{
  "name": "@checkmate/api",
  "version": "0.0.0",
  "private": true,
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc && copyfiles -u 1 src/**/*.html dist/",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@checkmate/shared-types": "workspace:*",
    "chess.js": "^1.0.0-beta.8",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^5.0.0",
    "express-rate-limit": "^7.2.0",
    "firebase-admin": "^12.0.0",
    "flutterwave-node-v3": "^1.4.1",
    "helmet": "^7.1.0",
    "multer": "^2.2.0",
    "resend": "^6.16.0",
    "socket.io": "^4.7.4",
    "stockfish": "^18.0.8",
    "winston": "^3.12.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@checkmate/config": "workspace:*",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/multer": "^2.2.0",
    "@types/node": "^20.11.24",
    "copyfiles": "^2.4.1",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.0.0"
  }
